stateDiagram-v2
  [*] --> NewSession : POST /api/user-chat/sessions
  NewSession --> Active : first message
  Active --> Renamed : PATCH /sessions/:id (title)
  Active --> Pinned : PATCH /sessions/:id (isPinned=true)
  Pinned --> Active : unpin
  Active --> Refreshed : POST /sessions/:id/refresh
  Refreshed --> Active
  Active --> Hidden : PATCH /sessions/:id (isVisible=false)
  Hidden --> Active : show again
  Active --> Expired : TTL reached
  Expired --> Cleaned : POST /cleanup
  Active --> Deleted : DELETE /sessions/:id
  Cleaned --> [*]
  Deleted --> [*]
