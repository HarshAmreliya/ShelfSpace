flowchart TB
  subgraph L1[Presentation Layer]
    app[app/* routes]
    comp[components/* feature UIs]
  end

  subgraph L2[State & Orchestration]
    ctx[contexts/* providers]
    hooks[hooks/* custom hooks]
  end

  subgraph L3[Domain/Service Layer]
    svc[services/* domain services]
    lib[lib/* API wrappers]
  end

  subgraph L4[External Systems]
    gw[NGINX gateway]
    micro[backend microservices]
  end

  app --> comp
  comp --> hooks
  hooks --> ctx
  hooks --> svc
  svc --> lib
  lib --> gw
  gw --> micro
