classDiagram
  class AnalyticsEvent {
    +string userId
    +string type
    +string timestamp
    +object payload
  }

  class AnalyticsDocument {
    +string userId
    +Stats stats
    +Map~MonthKey,MonthlyMetric~ monthly
    +Map~Genre,int~ genres
    +Map~Rating,int~ ratings
    +ActivityItem[] activity
    +Goals goals
    +string createdAt
    +string updatedAt
  }

  class Stats {
    +int totalBooks
    +int booksRead
    +int currentlyReading
    +int wantToRead
    +int totalPages
    +int totalReadingMinutes
    +float totalRating
    +int ratingCount
    +int currentStreak
    +int longestStreak
  }

  class MonthlyMetric {
    +int books
    +int pages
    +int minutes
  }

  class ActivityItem {
    +string id
    +string type
    +string title
    +string description
    +string timestamp
    +object metadata
  }

  class Goals {
    +int yearlyGoal
    +int monthlyPagesGoal
    +int monthlyHoursGoal
    +float targetRating
  }

  AnalyticsEvent --> AnalyticsDocument : projected_into
  AnalyticsDocument *-- Stats
  AnalyticsDocument *-- ActivityItem
  AnalyticsDocument *-- Goals
  AnalyticsDocument *-- MonthlyMetric
