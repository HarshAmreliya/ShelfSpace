flowchart TB
  subgraph UserDomain[user-service owns]
    U1[User]
    U2[Preferences]
    U3[UserStats]
    U4[UserGoal]
    U5[UserBadge]
    U6[ChatSession]
  end

  subgraph LibraryDomain[user-library-service owns]
    L1[ReadingList]
    L2[ReadingListBook]
  end

  subgraph ForumDomain[forum-service owns]
    F1[Forum]
    F2[ForumMembership]
    F3[ForumThread]
    F4[ForumPost]
    F5[ForumPostReaction]
  end

  subgraph ReviewDomain[review-service owns]
    R1[Review]
  end

  subgraph ChatDomain[chat-service owns]
    C1[Message]
  end

  subgraph AdminDomain[admin-service owns]
    A1[ModerationLog]
    A2[BookValidation]
  end

  subgraph BookDomain[book-service owns Mongo docs]
    B1[Book document]
  end

  subgraph AnalyticsDomain[analytics-service owns Mongo projections]
    N1[events]
    N2[analytics per-user document]
  end

  L2 -. references .-> B1
  R1 -. references .-> B1
  F2 -. references userId .-> U1
  C1 -. references senderId/groupId .-> U1
