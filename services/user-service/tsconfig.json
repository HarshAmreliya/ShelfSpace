{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "resolveJsonModule": true
  },
  "ts-node": {
    "esm": true
  },
  "include": ["src", "types", "script.js"],
  "exclude": ["node_modules", "src/__tests__"]
}
