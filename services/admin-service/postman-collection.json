              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/moderation/logs?limit=5&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["moderation", "logs"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get moderation logs with custom pagination"
