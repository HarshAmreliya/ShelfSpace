        {
          "name": "Get Moderation Logs - Default Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Logs are ordered by timestamp descending', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 1) {",
                  "        const firstTimestamp = new Date(jsonData[0].timestamp);",
                  "        const secondTimestamp = new Date(jsonData[1].timestamp);",
                  "        pm.expect(firstTimestamp.getTime()).to.be.at.least(secondTimestamp.getTime());",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/moderation/logs",
              "host": ["{{baseUrl}}"],
              "path": ["moderation", "logs"]
            },
            "description": "Get moderation logs with default pagination (limit=10, offset=0)"
          },
          "response": []
        },
        {
          "name": "Get Moderation Logs - Custom Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response respects limit', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.length).to.be.at.most(5);",
                  "});"
                ],
