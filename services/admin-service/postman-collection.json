        {
          "name": "Get Book Validation Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Response contains validation data', function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('id');",
                  "        pm.expect(jsonData).to.have.property('bookId');",
                  "        pm.expect(jsonData).to.have.property('status');",
                  "        pm.expect(['PENDING', 'APPROVED', 'REJECTED']).to.include(jsonData.status);",
                  "    });",
                  "} else {",
                  "    pm.test('404 response has error message', function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('error');",
                  "    });",
                  "}"
